{
	"files": ["src/index.ts"],
	"include": [
		"src/**/*",
		".scripts/**/**/*",
		"./eslint.config.ts",
		"./vitest.config.ts",
		"./svelte.config.ts"
	],
	"exclude": ["**/node_modules/**"],
	"compilerOptions": {
		"outDir": "./dist/",
		"noImplicitAny": true,
		"module": "preserve",
		"target": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"types": ["node", "/mnt/ssd2/repos/snavesutit/blockbench/types/index.d.ts"],
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"allowUmdGlobalAccess": true,
		"allowUnreachableCode": true,
		"esModuleInterop": true,
		"noEmit": true,
		"isolatedModules": true,
		"alwaysStrict": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@blockbench-types/*": ["/mnt/ssd2/repos/snavesutit/blockbench/types/*"]
		}
	}
}
